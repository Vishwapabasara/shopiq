# Shopify App Credentials
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_SCOPES=read_products,read_inventory,read_orders,read_collections

# App
APP_URL=https://shopiq.yourdomain.com
SESSION_SECRET=replace-with-32-char-random-secret
DEV_MODE=true

# MongoDB
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/shopiq

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=sk-...

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
TOKEN_ENCRYPTION_KEY=your-fernet-key-here

# SendGrid
SENDGRID_API_KEY=SG...
FROM_EMAIL=noreply@shopiq.yourdomain.com

# AWS S3 (for PDF reports)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=shopiq-reports
